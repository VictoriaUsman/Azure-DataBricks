# Copy this file to ~/.dbt/profiles.yml and fill in your values.
# Never commit the real profiles.yml — it contains your token.
#
# Community Edition: http_path is your CLUSTER endpoint
#   /sql/protocolv1/o/<org-id>/<cluster-id>
#   Found at: Compute → your cluster → Advanced Options → JDBC/ODBC
#
# Paid tier / SQL Warehouse: http_path is your WAREHOUSE endpoint
#   /sql/1.0/warehouses/<warehouse-id>
#   Found at: SQL Warehouses → your warehouse → Connection Details

retail_sales_platform:
  target: dev
  outputs:
    dev:
      type: databricks
      host:      "{{ env_var('DBT_DATABRICKS_HOST') }}"       # <workspace>.azuredatabricks.net
      http_path: "{{ env_var('DBT_DATABRICKS_HTTP_PATH') }}"  # see above
      token:     "{{ env_var('DBT_DATABRICKS_TOKEN') }}"      # personal access token
      schema: retail_platform
      threads: 4
      connect_retries: 3
      connect_timeout: 60
